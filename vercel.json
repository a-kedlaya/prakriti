{
    "outputDirectory": ".",
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/camera",
            "dest": "/camera.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}